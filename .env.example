# ================================================================
# INNOVEX – Environment Variables
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to version control.
# ================================================================

# ----------------------------------------------------------------
# Supabase (https://supabase.com/dashboard)
# ----------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ----------------------------------------------------------------
# Groq AI (https://console.groq.com/keys)
# Used for: Llama 3.3 70B (matchmaking / insights) and
#           Llama 3.1 8B Instant (daily missions)
# ----------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key

# ----------------------------------------------------------------
# Hugging Face (https://huggingface.co/settings/tokens)
# Used for: gte-small embedding model (vector matchmaking)
# ----------------------------------------------------------------
HUGGINGFACE_API_KEY=your_huggingface_api_key

# ----------------------------------------------------------------
# Google Calendar (https://console.cloud.google.com)
# Used for: Meeting scheduler with Google Meet links (optional)
# ----------------------------------------------------------------
GOOGLE_CALENDAR_CLIENT_ID=your_google_client_id
GOOGLE_CALENDAR_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ----------------------------------------------------------------
# LinkedIn (https://www.linkedin.com/developers/apps)
# Used for: One-click LinkedIn share OAuth (optional)
# ----------------------------------------------------------------
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/auth/linkedin/callback

# ----------------------------------------------------------------
# App URL (used for OAuth redirects and cron job auth)
# ----------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----------------------------------------------------------------
# Cron Secret (a random string you generate to secure cron routes)
# Generate with: openssl rand -base64 32
# ----------------------------------------------------------------
CRON_SECRET=your_cron_secret_key
